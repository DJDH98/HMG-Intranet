# Clerk publishable key (required for GitHub OAuth login gate)
# Get it from https://dashboard.clerk.com -> Your app -> API Keys
VITE_CLERK_PUBLISHABLE_KEY=

# (Optional) Base URL used for redirects in some environments
VITE_APP_BASE_URL=https://hmgintranet.vercel.app

# Google Gemini API key for local/dev journal AI tools.
# This stays server-side. Do not prefix it with VITE_.
GOOGLE_GEMINI_API_KEY=

# Optional override. Defaults to gemini-2.5-flash-lite.
GEMINI_MODEL=gemini-2.5-flash-lite

# Upstash Redis database for persistent journal entries.
# Install/provision Upstash through the Vercel Marketplace so these are injected in Vercel.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Vercel Deployment Notes ---
# 1. In Vercel Dashboard: Project -> Settings -> Environment Variables
# 2. Add VITE_CLERK_PUBLISHABLE_KEY, GOOGLE_GEMINI_API_KEY, and the Upstash Redis variables for Production + Preview environments
# 3. Redeploy after adding the variables
# 4. Local dev: copy this file to .env and fill the keys you want to test
